{
  "name": "catalog",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "vitest"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "prettier": "^3.5.3",
    "turbo": "^2.5.2",
    "typescript": "5.8.2",
    "vitest": "^2.1.3"
  },
  "packageManager": "pnpm@9.1.1",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "autoprefixer": "^10.4.19"
  },
  "pnpm": {
    "overrides": {
      "@types/react-dom": "19.1.3"
    }
  }
}
