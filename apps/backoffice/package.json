    "@sentry/nextjs": "^9.15.0",
    "lucide-react": "^0.428.0",
    "next": "15.3.1",
    "next-intl": "^3.17.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.52.2",
    "recharts": "^2.12.7",
    "use-debounce": "^10.0.3",
    "zod": "link:@hookform/resolvers/zod",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
