{
  "name": "collaboration",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack --port 3001",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "prisma-migration-deploy": "prisma migrate deploy --schema=../../packages/model/prisma/schema.prisma",
    "prisma-generate": "prisma generate --schema=../../packages/model/prisma/schema.prisma",
    "vercel-build": "pnpm run prisma-generate && pnpm prisma-migration-deploy && next build"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@repo/model": "workspace:*",
    "@repo/ui": "workspace:*",
    "@sentry/nextjs": "^8.32.0",
    "lucide-react": "^0.428.0",
    "next": "15.3.1",
    "next-auth": "5.0.0-beta.21",
    "next-intl": "^3.17.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.52.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^20",
    "@types/react": "19.1.2",
    "@types/react-dom": "19.1.3",
    "eslint": "^8",
    "eslint-config-next": "15.3.1",
    "prisma": "5.19.1",
    "typescript": "^5",
    "zod-prisma": "^0.5.4"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.1.2",
      "@types/react-dom": "19.1.3"
    }
  }
}
