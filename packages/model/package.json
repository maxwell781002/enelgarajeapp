{
  "name": "@repo/model",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=v20.15.1"
  },
  "exports": {
    "./model/*": "./src/*.ts"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "scripts": {
    "prisma-generate": "prisma generate --schema=./prisma/schema.prisma",
    "prisma-create-migration": "prisma migrate dev --create-only --schema=./prisma/schema.prisma",
    "prisma-migration-deploy": "prisma migrate deploy --schema=./prisma/schema.prisma",
    "prisma-reset": "prisma migrate reset --schema=./prisma/schema.prisma"
  },
  "devDependencies": {
    "@prisma/client": "5.13.0",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^20.14.12",
    "dotenv-cli": "^7.4.2",
    "prisma": "5.13.0",
    "ts-node": "^10.9.2",
    "zod-prisma": "^0.5.4"
  },
  "dependencies": {
    "slugify": "^1.6.6",
    "zod": "^3.23.8"
  }
}
