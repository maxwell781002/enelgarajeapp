{
  "name": "@repo/model",
  "version": "0.0.0",
  "private": true,
  "exports": {
    "./model/*": "./src/*.ts"
  },
  "scripts": {
    "prisma-generate": "dotenv -e ../../.env -- prisma generate --schema=./prisma/schema.prisma",
    "prisma-create-migration": "dotenv -e ../../.env -- prisma migrate dev --create-only --schema=./prisma/schema.prisma",
    "prisma-migration-deploy": "dotenv -e ../../.env -- prisma migrate deploy --schema=./prisma/schema.prisma",
    "prisma": "prisma"
  },
  "devDependencies": {
    "@prisma/client": "5.13.0",
    "prisma": "5.13.0",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "dotenv-cli": "^7.4.2",
    "typescript": "^5.3.3",
    "zod-prisma": "^0.5.4"
  },
  "dependencies": {
    "zod": "^3.23.8"
  }
}
